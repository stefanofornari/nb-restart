<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE filesystem PUBLIC "-//NetBeans//DTD Filesystem 1.2//EN"
          "https://www.netbeans.org/dtds/filesystem-1_2.dtd">

<!--
  layer.xml 1 NetBeans module layer for the Restart IDE plugin.

  Added global keybinding registration for the Restart IDE action
  Ctrl+Shift+Delete (CS-DELETE).
-->
<filesystem>
  <folder name="Actions">
    <folder name="Keybindings">
      <file name="ste-netbeans-restart-RestartIDEAction.instance">
        <attr name="keybinding-shortcut" string="CS-BACK_SPACE"/>
        <attr name="iconBase" stringvalue="ste/netbeans/restart/restart-16x16.png"/>
      </file>
    </folder>
  </folder>
</filesystem>
